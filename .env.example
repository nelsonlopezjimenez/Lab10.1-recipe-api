# ============================================================================
#  ENVIRONMENT VARIABLES — copy this file to `.env` and fill in real values
# ============================================================================
#  `.env` is already listed in .gitignore — it must NEVER be committed.
#  This `.env.example` file IS meant to be committed: it documents which
#  variables the app expects, with safe placeholder values, so a teammate
#  (or a student cloning this repo) knows exactly what to create.
#
#  Loaded automatically by the `import 'dotenv/config'` line at the top of
#  index.js — every key below becomes available as `process.env.<KEY>`
#  anywhere in the app, as soon as the app starts.
#
#  See MONGO_CONFIG_SCENARIOS.md for a full discussion of the Mongo-related
#  options below (why two "shapes" of config are shown, and how to choose
#  between them), and ANALYSIS.md §9 for the security/auth variables.
# ============================================================================


# ---------------------------------------------------------------------------
# SERVER
# ---------------------------------------------------------------------------

# The port Express listens on. index.js reads it as:
#     const port = process.env.PORT || 3999;
# That `|| 3999` fallback is what lets the app run locally with NO `.env` at
# all — but hosting platforms (Render, Railway, Heroku, Fly.io...) ASSIGN a
# port at deploy time via this exact variable. Reading from `process.env`
# instead of hardcoding `3999` is what makes one codebase work in both
# places, unchanged.
PORT=3999

# Conventional flag for "which environment am I running in." Nothing in this
# codebase reads it yet — but Express, many libraries, and your own code can
# branch on it (e.g. "log verbosely in development, quietly in production").
# Typical values: development | production | test
NODE_ENV=development


# ---------------------------------------------------------------------------
# MONGODB CONNECTION  — pick ONE of the two shapes below, not both
# ---------------------------------------------------------------------------
# Both blocks describe the exact same local database; they're shown together
# only so you can compare the two common "shapes" a Mongo config can take.
# MONGO_CONFIG_SCENARIOS.md §2 walks through when each is worth choosing.

# --- Shape 1: ONE full connection string (simplest; what this app would use
#              if its hardcoded URI in models/index.js were externalized) ---
#     mongodb://<host>:<port>/<database-name>
MONGODB_URI=mongodb://127.0.0.1:27017/test030

# Hosted/cloud Mongo (e.g. MongoDB Atlas) looks like this instead — note the
# `+srv`, the credentials embedded in the URI, and the extra query params.
# Uncomment and fill in your own cluster's details to point this app at the
# cloud instead of a local install (no other code changes needed):
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database-name>?retryWrites=true&w=majority

# --- Shape 2: the SAME connection, broken into named parts that your code
#              composes into a URI at startup (e.g. `mongodb://${MONGO_HOST}:
#              ${MONGO_PORT}/${MONGO_DB_NAME}`) ---
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_DB_NAME=test030


# ---------------------------------------------------------------------------
# AUTH — not used by the app yet; placeholders for the roadmap in
# ANALYSIS.md §9 ("Security & authentication — why and how")
# ---------------------------------------------------------------------------

# A long, random, secret string used to SIGN tokens (e.g. JSON Web Tokens) or
# server-side sessions — it's what lets the server tell "a token I actually
# issued" apart from "a token someone forged by guessing." Treat it exactly
# like a password: long, random, unique per project, never logged, never
# committed. Generate a real one with:
#     node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string-before-use


# ---------------------------------------------------------------------------
# CORS  — see the CORS comment in index.js and ANALYSIS.md §9
# ---------------------------------------------------------------------------

# Which frontend origin is allowed to call this API from a browser. The app
# currently calls `cors()` with NO options, which allows literally any
# origin — convenient for local development, but too permissive for a real
# deployment. A hardened setup would read this variable and pass it to
# `cors({ origin: process.env.CORS_ORIGIN })`.
CORS_ORIGIN=http://localhost:5173
