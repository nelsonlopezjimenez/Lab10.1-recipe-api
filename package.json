{
  "name": "recipe-api-updated",
  "version": "2.0.0",
  "description": "Modern Recipe API with Express, MongoDB, and comprehensive testing",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "cross-env NODE_ENV=test jest --watchAll --no-cache --detectOpenHandles",
    "test:ci": "cross-env NODE_ENV=test jest --ci --coverage --watchAll=false",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write src/**/*.js"
  },
  "keywords": [
    "express",
    "mongodb",
    "mongoose",
    "api",
    "rest",
    "nodejs",
    "recipe",
    "testing",
    "jest",
    "supertest"
  ],
  "author": "Nelson Lopez (Updated 2025)",
  "license": "ISC",
  "dependencies": {
    "express": "^4.21.2",
    "mongoose": "^8.17.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "helmet": "^8.0.0",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "compression": "^1.7.5",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "mongodb-memory-server": "^10.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/src/test/setup.js"],
    "testMatch": ["<rootDir>/src/test/**/*.test.js"],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/test/**",
      "!src/server.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"],
    "testTimeout": 30000
  },
  "engines": {
    "node": ">=18.0.0"
  }
}